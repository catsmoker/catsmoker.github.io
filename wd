#region Action Functions (Defined as ScriptBlocks for Jobs)

# IMPORTANT: Functions intended to be run inside Start-Job must be defined
#            using the `function:` scope explicitly when passed as ScriptBlock,
#            OR defined directly inside the Start-Job -ScriptBlock parameter.
#            Using ${function:FunctionName} ensures the *current* definition is passed.
#            Alternatively, define the core logic within the Start-Job call itself.

Function Clean-Windows_Job {
    # This code runs in the background job's process
    Write-Host "Job: Cleaning Windows..."
    $ErrorActionPreference = 'Stop' # Optional: Stop on errors within the job

    try {
        # Clean User Temp Folder
        $userTempPath = $env:TEMP
        Write-Host "Job: Clearing user temp folder: $userTempPath"
        Get-ChildItem -Path $userTempPath -Recurse -Force -ErrorAction SilentlyContinue | ForEach-Object {
            try { Remove-Item -Path $_.FullName -Recurse -Force } catch { Write-Warning "Job: Could not remove '$($_.FullName)': $($_.Exception.Message)" }
        }
        Write-Host "Job: User temp folder cleared."

        # Clean Windows Temp Folder
        $windowsTempPath = Join-Path -Path $env:windir -ChildPath "Temp"
        Write-Host "Job: Clearing Windows temp folder: $windowsTempPath"
        Get-ChildItem -Path $windowsTempPath -Recurse -Force -ErrorAction SilentlyContinue | ForEach-Object {
            try { Remove-Item -Path $_.FullName -Recurse -Force } catch { Write-Warning "Job: Could not remove '$($_.FullName)': $($_.Exception.Message)" }
        }
         Write-Host "Job: Windows temp folder cleared."

        # Clean Recycle Bin (Requires interaction - cannot be fully backgrounded without external tools/complex methods)
        # We will skip the interactive part in the background job.
        # Consider adding a separate button or changing this function if interactive delete is essential.
        Write-Host "Job: Skipping interactive Recycle Bin clear in background job."
        # If you MUST clear it silently: Clear-RecycleBin -Force (PowerShell 5+) - Use with caution!
        # try { Clear-RecycleBin -Force -ErrorAction Stop } catch { Write-Warning "Job: Failed to clear Recycle Bin silently: $($_.Exception.Message)"}

        # Flush DNS Cache
        Write-Host "Job: Flushing DNS Cache..."
        try {
            Start-Process -FilePath "ipconfig.exe" -ArgumentList "/flushdns" -NoNewWindow -Wait
        } catch {
            Write-Warning "Job: Failed to flush DNS cache: $($_.Exception.Message)"
        }

        Write-Host "Job: Cleanup task completed."
        return "Cleanup completed." # Optional: Return a success message

    } catch {
        Write-Error "Job Error during cleanup: $($_.Exception.Message)"
        throw "Error during cleanup: $($_.Exception.Message)" # Re-throw to make the job fail
    }
}

Function Fix-Windows_Job {
    Write-Host "Job: Scanning and fixing Windows..."
    $ErrorActionPreference = 'Stop'
    try {
        Write-Host "Job: Running chkdsk /scan..."
        Start-Process -FilePath "chkdsk.exe" -ArgumentList "/scan /perf" -NoNewWindow -Wait
        Write-Host "Job: Check Disk (Scan) completed."

        Write-Host "Job: Running sfc /scannow..."
        Start-Process -FilePath "sfc.exe" -ArgumentList "/scannow" -NoNewWindow -Wait
        Write-Host "Job: System File Checker completed."

        Write-Host "Job: Running DISM /Online /Cleanup-Image /RestoreHealth..."
        Start-Process -FilePath "DISM.exe" -ArgumentList "/Online /Cleanup-Image /RestoreHealth" -NoNewWindow -Wait
        Write-Host "Job: DISM completed."

        Write-Host "Job: Windows Fix sequence completed."
        return "Windows Fix sequence completed."
    } catch {
        Write-Error "Job Error during Fix sequence: $($_.Exception.Message)"
        throw "Error during Fix sequence: $($_.Exception.Message)"
    }
}

