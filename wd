        throw "Error during activation attempt: $($_.Exception.Message)"
    }
}


Function Run-WindowsUpdate_Job {
    Write-Host "Job: Checking for Windows Updates..."
    $ErrorActionPreference = 'Stop'
    $moduleName = "PSWindowsUpdate"
    $logFileName = "$($env:computername)-$(Get-Date -f yyyy-MM-dd)-MSUpdates.log"
    $logFilePath = Join-Path $env:TEMP $logFileName

    try {
        # Check/Install Module
        if (-not (Get-Module -ListAvailable -Name $moduleName)) {
            Write-Host "Job: Installing PSWindowsUpdate module..."
            if (-not (Get-PackageProvider -Name NuGet -ErrorAction SilentlyContinue)) {
                Install-PackageProvider -Name NuGet -MinimumVersion 2.8.5.201 -Force -Confirm:$false
            }
            Install-Module $moduleName -Force -AcceptLicense -Scope CurrentUser -Confirm:$false
             Write-Host "Job: PSWindowsUpdate module installed."
        } else {
             Write-Host "Job: PSWindowsUpdate module already installed."
        }
        Import-Module $moduleName -Force

        # Add MS Update Service
        Write-Host "Job: Registering Microsoft Update service..."
        Add-WUServiceManager -ServiceID "7971f918-a847-4430-9279-4a52d1efe18d" -Confirm:$false -ErrorAction SilentlyContinue

        # Install Updates
        Write-Host "Job: Checking for and installing updates (logging to $logFilePath)..."
        # Consider removing -AutoReboot for safety unless explicitly desired.
        # Add -IgnoreReboot to prevent reboot but signal one might be needed.
        Install-WindowsUpdate -MicrosoftUpdate -AcceptAll -IgnoreReboot -Verbose | Out-File $logFilePath -Append

        Write-Host "Job: Windows Update check and installation process completed."
        return "Windows Update process completed. Check log: $logFilePath" # Return log path
    } catch {
         Write-Error "Job Error during Windows Update: $($_.Exception.Message)"
         throw "Error during Windows Update: $($_.Exception.Message)"
    }
}

Function Run-CTT_Job {
