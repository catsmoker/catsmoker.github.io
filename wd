            $packageList = $checkedBoxes | ForEach-Object { @{ Name = $_.Text; ID = $_.Name } }

            # Define the installation scriptblock
            $installScriptBlock = {
                param($PackagesToInstall) # Receive the list of packages

                Write-Host "Job: Starting App Installation Process..."
                $ErrorActionPreference = 'Continue' # Continue even if one app fails

                # Run Upgrade All First
                Write-Host "Job: Running 'winget upgrade --all'..."
                try {
                    Start-Process "winget" -ArgumentList "upgrade --all --silent --accept-package-agreements --accept-source-agreements --disable-interactivity --include-unknown" -Wait -NoNewWindow -ErrorAction Stop
                    Write-Host "Job: 'winget upgrade --all' completed."
                } catch {
                    Write-Warning "Job: Error during 'winget upgrade --all': $($_.Exception.Message)"
                }

                # Install Selected Packages
                Write-Host "Job: Installing selected packages..."
                $total = $PackagesToInstall.Count
                $current = 0
                foreach ($packageInfo in $PackagesToInstall) {
                    $current++
                    $packageName = $packageInfo.Name
                    $packageId = $packageInfo.ID
                    Write-Host "Job: Installing '$packageName' (ID: $packageId) ($current/$total)..."
                    # Write-Progress can be used here, but won't show on GUI directly
                    # Write-Progress -Activity "Installing Apps" -Status "Installing $packageName ($current/$total)" -PercentComplete (($current / $total) * 100)

                    try {
                        Start-Process "winget" -ArgumentList "install -e --id `"$packageId`" --silent --accept-package-agreements --accept-source-agreements --disable-interactivity --force" -Wait -NoNewWindow -ErrorAction Stop
                        Write-Host "Job: '$packageName' installation command completed."
                    } catch {
                         Write-Warning "Job: Failed to install '$packageName': $($_.Exception.Message)"
                    }
                }
                Write-Host "Job: App installation process finished."
                return "App installation process finished."
            }

            # Start the installation job
            Start-Action -Name "Install Apps" -ScriptBlock $installScriptBlock -ArgumentList (,$packageList) # Pass package list as argument array
        }
    } else {
        Update-Status "App installation cancelled."
    }
}

Function Activate-Windows_Job {
    # Added back as requested, runs in background after confirmation
    Write-Host "Job: Attempting Windows activation using online script..."
    $ErrorActionPreference = 'Stop'
    try {
        # IMPORTANT: This command executes remote code directly.
        Invoke-Expression (Invoke-RestMethod 'https://get.activated.win')
        Write-Host "Job: Activation script execution attempted."
