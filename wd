# Helper to safely update GUI controls from any thread
Function Update-GuiControl {
    param(
        [System.Windows.Forms.Control]$Control,
        [scriptblock]$UpdateAction
    )
    if ($Control.InvokeRequired) {
        $Control.Invoke($UpdateAction)
    } else {
        Invoke-Command $UpdateAction
    }
}

# Helper to update Status Label and Progress Bar
Function Update-Status {
    param(
        [string]$Message,
        [int]$Progress = -1, # Not used with Marquee progress, but kept for potential future use
        [bool]$IsRunning = $false
    )
    Update-GuiControl -Control $script:statusLabel -UpdateAction {
        $script:statusLabel.Text = $Message
    }
    Update-GuiControl -Control $script:progressBar -UpdateAction {
        if ($IsRunning) {
            $script:progressBar.Style = 'Marquee'
            $script:progressBar.MarqueeAnimationSpeed = 30 # Start animation
        } else {
            $script:progressBar.MarqueeAnimationSpeed = 0 # Stop animation
            $script:progressBar.Style = 'Continuous' # Switch back to allow setting Value
            $script:progressBar.Value = ($Progress -eq 100) ? 100 : 0 # Show 100% on completion, 0 otherwise
        }
    }
}

# Helper to enable/disable action buttons
Function Set-ActionButtonsState {
    param([bool]$Enabled)
    foreach ($button in $script:actionButtons) {
        Update-GuiControl -Control $button -UpdateAction {
            $button.Enabled = $Enabled
        }
    }
}

# Function to stop the current job if it exists
Function Stop-CurrentJob {
    if ($script:currentJob -ne $null -and $script:currentJob.JobStateInfo.State -eq [System.Management.Automation.JobState]::Running) {
        try {
            Write-Host "Attempting to stop running job $($script:currentJob.Name)..."
            Stop-Job -Job $script:currentJob -ErrorAction SilentlyContinue
            # Give it a moment to stop
            Start-Sleep -Milliseconds 200
        } catch {
            Write-Warning "Error trying to stop job $($script:currentJob.Name): $($_.Exception.Message)"
        }
    }
    if ($script:currentJob -ne $null) {
        Remove-Job -Job $script:currentJob -Force -ErrorAction SilentlyContinue
        $script:currentJob = $null
    }
}

# Function to start an action in a background job
Function Start-Action {
    param(
        [string]$Name,
        [scriptblock]$ScriptBlock,
        [switch]$Confirm,
        [string]$ConfirmMessage = "Are you sure you want to proceed?"
    )

    if ($script:currentJob -ne $null) {
        [System.Windows.Forms.MessageBox]::Show("Another task is already running. Please wait for it to complete.", "Task in Progress", [System.Windows.Forms.MessageBoxButtons]::OK, [System.Windows.Forms.MessageBoxIcon]::Warning)
        return
    }

    if ($Confirm) {
        $dialogResult = [System.Windows.Forms.MessageBox]::Show($ConfirmMessage, "Confirmation Required", [System.Windows.Forms.MessageBoxButtons]::YesNo, [System.Windows.Forms.MessageBoxIcon]::Warning)
        if ($dialogResult -ne [System.Windows.Forms.DialogResult]::Yes) {
            Update-Status "Action '$Name' cancelled by user."
            return
        }
    }

    Write-Host "--- Starting Action: $Name ---"
    Set-ActionButtonsState -Enabled $false
    $script:mainForm.Cursor = [System.Windows.Forms.Cursors]::WaitCursor
    Update-Status "Starting: $Name..." -IsRunning $true

    try {
        # Pass necessary variables or functions if needed by the job
        # Note: Functions defined in the main script are generally available in the job's scriptblock
        $script:currentJob = Start-Job -Name $Name -ScriptBlock $ScriptBlock -ErrorAction Stop
        $script:jobCheckTimer.Start()
    } catch {
        $errMsg = "Failed to start job '$Name': $($_.Exception.Message)"
        Write-Error $errMsg
        Update-Status "Error starting job: $Name" -IsRunning $false
        [System.Windows.Forms.MessageBox]::Show($errMsg, "Job Start Error", [System.Windows.Forms.MessageBoxButtons]::OK, [System.Windows.Forms.MessageBoxIcon]::Error)
        Set-ActionButtonsState -Enabled $true
        $script:mainForm.Cursor = [System.Windows.Forms.Cursors]::Default
        $script:currentJob = $null # Ensure it's null
    }
}

# Timer event handler to check job status
Function Check-JobStatus {
    if ($script:currentJob -eq $null) {
        $script:jobCheckTimer.Stop()
        Return
    }

    $jobState = $script:currentJob.JobStateInfo.State
    $jobName = $script:currentJob.Name

    if ($jobState -in ([System.Management.Automation.JobState]::Completed, [System.Management.Automation.JobState]::Failed, [System.Management.Automation.JobState]::Stopped)) {
        $script:jobCheckTimer.Stop()
        Write-Host "Job '$jobName' finished with state: $jobState"
        $finalMessage = ""
        $messageBoxIcon = [System.Windows.Forms.MessageBoxIcon]::Information
        $messageBoxTitle = "Task Complete"

        # Receive job output/errors
        $jobOutput = Receive-Job -Job $script:currentJob -Keep # Use -Keep to allow receiving multiple times if needed, though usually not here.
        # Process output if needed (e.g., Write-Host it)
        if ($jobOutput) {
            Write-Host "--- Job '$jobName' Output ---"
            $jobOutput | ForEach-Object { Write-Host $_ }
            Write-Host "--- End Job Output ---"
        }


        if ($jobState -eq [System.Management.Automation.JobState]::Failed) {
            $errorMessage = "Error: Task '$jobName' failed."
            # Check for specific errors in the job's error stream
            if ($script:currentJob.Error) {
                 $detailedError = ($script:currentJob.Error | Select-Object -First 1).Exception.Message
                 $errorMessage += "`n`nDetails: $detailedError"
                 Write-Error "Job '$jobName' Error: $detailedError"
            }
            $finalMessage = $errorMessage
            $messageBoxIcon = [System.Windows.Forms.MessageBoxIcon]::Error
            $messageBoxTitle = "Task Error"
            Update-Status $finalMessage -IsRunning $false
            [System.Windows.Forms.MessageBox]::Show($finalMessage, $messageBoxTitle, [System.Windows.Forms.MessageBoxButtons]::OK, $messageBoxIcon)

        } elseif ($jobState -eq [System.Management.Automation.JobState]::Stopped) {
            $finalMessage = "Task '$jobName' was stopped."
             Update-Status $finalMessage -IsRunning $false
             [System.Windows.Forms.MessageBox]::Show($finalMessage, "Task Stopped", [System.Windows.Forms.MessageBoxButtons]::OK, [System.Windows.Forms.MessageBoxIcon]::Warning)
        } else { # Completed
            $finalMessage = "Task '$jobName' completed successfully."
            Update-Status $finalMessage -Progress 100 -IsRunning $false
            # Optionally show a success message box, or just rely on status label
            # [System.Windows.Forms.MessageBox]::Show($finalMessage, $messageBoxTitle, [System.Windows.Forms.MessageBoxButtons]::OK, $messageBoxIcon)
        }

        # Cleanup
        Remove-Job -Job $script:currentJob -Force -ErrorAction SilentlyContinue
        $script:currentJob = $null
        Set-ActionButtonsState -Enabled $true
        $script:mainForm.Cursor = [System.Windows.Forms.Cursors]::Default
        Write-Host "--- Action Finished: $jobName ---"
    } else {
        # Job still running, maybe update status with generic message or progress if implemented
         Update-Status "Running: $jobName..." -IsRunning $true
         # If the job uses Write-Progress, you could potentially receive and parse it here,
         # but for simplicity, we are just showing "Running...".
    }
}

