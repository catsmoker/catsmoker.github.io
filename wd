#region Helper Functions (GUI Update - Simplified)

Function Update-GuiControl { param([System.Windows.Forms.Control]$Control, [scriptblock]$UpdateAction)
    if ($Control.InvokeRequired) { $Control.Invoke($UpdateAction) } else { Invoke-Command $UpdateAction }
}

# Simplified Status Update for Synchronous Tasks
Function Update-Status { param([string]$Message, [int]$Progress = 0) # Default progress 0
    Update-GuiControl -Control $script:statusLabel -UpdateAction { $script:statusLabel.Text = $Message }
    Update-GuiControl -Control $script:progressBar -UpdateAction {
        $script:progressBar.Style = 'Continuous'
        # Ensure progress is within bounds
        $clampedProgress = [Math]::Max(0, [Math]::Min(100, $Progress))
        $script:progressBar.Value = $clampedProgress
    }
    # Force GUI update (might help slightly with perceived responsiveness between steps)
    [System.Windows.Forms.Application]::DoEvents()
}

# Function to run actions synchronously with status updates & error handling
Function Run-SynchronousAction {
    param(
        [string]$Name,
        [scriptblock]$Action,
        [switch]$Confirm,
        [string]$ConfirmMessage = "Are you sure?"
    )
    if ($Confirm) {
        $dialogResult = [System.Windows.Forms.MessageBox]::Show($ConfirmMessage, "Confirmation Required", [System.Windows.Forms.MessageBoxButtons]::YesNo, [System.Windows.Forms.MessageBoxIcon]::Warning)
        if ($dialogResult -ne [System.Windows.Forms.DialogResult]::Yes) {
            Update-Status "Action '$Name' cancelled by user." 0
            return
        }
    }

    Write-Host "--- Starting Action (Sync): $Name ---"
    Update-Status "Starting: $Name..." 5 # Small progress indication
    $script:mainForm.Cursor = [System.Windows.Forms.Cursors]::WaitCursor
    $success = $false
    try {
        Invoke-Command $Action # Execute the scriptblock directly
        Update-Status "Action '$Name' completed." 100
        Write-Host "--- Action Finished (Sync): $Name ---"
        $success = $true
    } catch {
        $errMsg = "Error during action '$Name': $($_.Exception.Message)"
        Write-Error $errMsg
        Update-Status $errMsg 0
        [System.Windows.Forms.MessageBox]::Show($errMsg, "Action Error", [System.Windows.Forms.MessageBoxButtons]::OK, [System.Windows.Forms.MessageBoxIcon]::Error)
    } finally {
        $script:mainForm.Cursor = [System.Windows.Forms.Cursors]::Default
        # Optionally show success message box
        # if ($success) { [System.Windows.Forms.MessageBox]::Show("Action '$Name' completed successfully.", "Success", [System.Windows.Forms.MessageBoxButtons]::OK, [System.Windows.Forms.MessageBoxIcon]::Information) }
    }
}

