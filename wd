Function Run-WindowsUpdate {
     Run-SynchronousAction -Name "Windows Update" -Action {
        $ErrorActionPreference = 'Stop'
        $moduleName = "PSWindowsUpdate"; $logFileName = "$($env:computername)-$(Get-Date -f yyyy-MM-dd)-MSUpdates.log"; $logFilePath = Join-Path $env:TEMP $logFileName
        Update-Status "Updating: Checking/Installing PSWindowsUpdate..." 10
        if (-not (Get-Module -ListAvailable -Name $moduleName)) {
            Write-Host "Installing PSWindowsUpdate module..."
            if (-not (Get-PackageProvider -Name NuGet -ErrorAction SilentlyContinue)) { Install-PackageProvider -Name NuGet -MinimumVersion 2.8.5.201 -Force -Confirm:$false }
            Install-Module $moduleName -Force -AcceptLicense -Scope CurrentUser -Confirm:$false
        }
        Import-Module $moduleName -Force
        Update-Status "Updating: Registering MS Update Service..." 30
        Add-WUServiceManager -ServiceID "7971f918-a847-4430-9279-4a52d1efe18d" -Confirm:$false -ErrorAction SilentlyContinue
        Update-Status "Updating: Installing updates (logging to $logFilePath)..." 50
        Install-WindowsUpdate -MicrosoftUpdate -AcceptAll -IgnoreReboot -Verbose | Out-File $logFilePath -Append
        Update-Status "Windows Update completed. Log: $logFilePath" 100 # Show log path
    }
}

Function Run-CTT {
     Run-SynchronousAction -Name "CTT Windows Utility" -Action {
        # This action launches a separate window, so the GUI freeze is minimal.
        $command = "iwr -useb https://christitus.com/win | iex"
        Start-Process "powershell.exe" -ArgumentList "-NoProfile -ExecutionPolicy Bypass -Command `"$command`""
        Update-Status "CTT Utility launch command executed." 50 # Set progress mid-way as it hands off
    }
}

Function Scan-WithMRT {
    Run-SynchronousAction -Name "Virus Scan (MRT)" -Action {
        $mrtPath = Join-Path -Path $env:SystemRoot -ChildPath "System32\MRT.exe"
        if (-not (Test-Path $mrtPath)) { throw "MRT.exe not found at $mrtPath" }
        Update-Status "Scanning: Launching MRT.exe /F..." 50
        Start-Process -FilePath $mrtPath -ArgumentList "/F" -Wait # GUI freezes until MRT closes
    }
}
#endregion Action Functions

#region Display GUI
# Show the main form and start message loop
try {
    Write-Host "Displaying main application window..."
    Write-Host "NOTE: The console window running this script may become unresponsive while the GUI is open." -ForegroundColor Yellow
    Write-Host "NOTE: The GUI WILL FREEZE during long-running tasks." -ForegroundColor Yellow
    Update-Status "Ready" 0 # Initial status
    # .ShowDialog() blocks the current thread (the one running iex)
    $script:mainForm.ShowDialog() | Out-Null
    Write-Host "Application window closed."
} catch {
    Write-Error "An unexpected error occurred with the GUI: $($_.Exception.Message)"
    [System.Windows.Forms.MessageBox]::Show("An unexpected GUI error occurred: $($_.Exception.Message)", "GUI Error", [System.Windows.Forms.MessageBoxButtons]::OK, [System.Windows.Forms.MessageBoxIcon]::Error)
} finally {
    # Final cleanup
    if ($script:mainForm -ne $null -and -not $script:mainForm.IsDisposed) {
        $script:mainForm.Dispose()
        $script:mainForm = $null
        Write-Host "GUI resources released."
    }
}
#endregion Display GUI

Write-Host "Script execution finished."
