Function Scan-WithMRT_Job {
     Write-Host "Job: Preparing Windows Malicious Software Removal Tool (MRT)..."
     $ErrorActionPreference = 'Stop'
    try {
        $mrtPath = Join-Path -Path $env:SystemRoot -ChildPath "System32\MRT.exe"
        if (-not (Test-Path $mrtPath)) {
            throw "MRT.exe not found at expected location: $mrtPath"
        }
        Write-Host "Job: Launching MRT.exe /F (Full Scan)..."
        # MRT is interactive, so the job just launches it. User interacts directly.
        Start-Process -FilePath $mrtPath -ArgumentList "/F" -Wait
        # The -Wait here will make the *job* wait until MRT closes.
        Write-Host "Job: MRT Scan window closed."
        return "MRT Scan window closed."
    } catch {
        Write-Error "Job Error running MRT Scan: $($_.Exception.Message)"
        throw "Error running MRT Scan: $($_.Exception.Message)"
    }
}
