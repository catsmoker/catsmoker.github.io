Function Clean-Windows {
    Run-SynchronousAction -Name "Clean Windows" -Action {
        $ErrorActionPreference = 'SilentlyContinue' # Continue on remove errors
        Update-Status "Cleaning: User Temp..." 20
        Get-ChildItem -Path $env:TEMP -Recurse -Force | Remove-Item -Recurse -Force
        Update-Status "Cleaning: Windows Temp..." 40
        Get-ChildItem -Path "$env:windir\Temp" -Recurse -Force | Remove-Item -Recurse -Force

        Update-Status "Checking Recycle Bin..." 60
        $RecycleBin = New-Object -ComObject Shell.Application
        $BinItems = $RecycleBin.NameSpace(0xA).Items()
        if ($BinItems.Count -gt 0) {
             # Confirmation MUST happen before the synchronous action starts ideally,
             # but we'll do it here for simplicity in this structure.
             $confirm = [System.Windows.Forms.MessageBox]::Show("Empty the Recycle Bin?", "Confirm", [System.Windows.Forms.MessageBoxButtons]::YesNo, [System.Windows.Forms.MessageBoxIcon]::Warning)
             if ($confirm -eq [System.Windows.Forms.DialogResult]::Yes) {
                 Update-Status "Cleaning: Emptying Recycle Bin..." 70
                 $BinItems | ForEach-Object { $_.InvokeVerb("delete") } # May still have issues depending on UAC/Permissions
                 # Alternative/More Robust: Clear-RecycleBin -Force (Requires PS 5+)
             } else { Write-Host "Recycle Bin skipped by user."}
        } else { Write-Host "Recycle Bin is empty." }

        Update-Status "Cleaning: Flushing DNS..." 90
        ipconfig /flushdns | Out-Null
        $ErrorActionPreference = 'Stop' # Reset error preference
    }
}

Function Fix-Windows {
    Run-SynchronousAction -Name "Scan and Fix Windows" -Action {
        $ErrorActionPreference = 'Stop'
        Update-Status "Fixing: Running chkdsk /scan..." 10
        Start-Process -FilePath "chkdsk.exe" -ArgumentList "/scan /perf" -NoNewWindow -Wait
        Update-Status "Fixing: Running sfc /scannow..." 40
        Start-Process -FilePath "sfc.exe" -ArgumentList "/scannow" -NoNewWindow -Wait
        Update-Status "Fixing: Running DISM..." 70
        Start-Process -FilePath "DISM.exe" -ArgumentList "/Online /Cleanup-Image /RestoreHealth" -NoNewWindow -Wait
    }
}

