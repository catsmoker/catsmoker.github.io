#region Initial Checks (Admin, OS)

# --- Admin Check & Relaunch Handling for iex ---
Write-Host "Checking if running as administrator..."
$currentUser = [System.Security.Principal.WindowsIdentity]::GetCurrent()
$windowsPrincipal = New-Object System.Security.Principal.WindowsPrincipal($currentUser)
$adminRole = [System.Security.Principal.WindowsBuiltInRole]::Administrator

if (-not $windowsPrincipal.IsInRole($adminRole)) {
    Write-Host "Admin privileges required. Attempting to relaunch..." -ForegroundColor Yellow
    try {
        # Download the script content again to ensure we have it locally
        Write-Host "Downloading script for elevation..."
        $scriptContent = Invoke-RestMethod -Uri $scriptUrl -UseBasicParsing -ErrorAction Stop

        # Save to a temporary file
        $tempScriptPath = Join-Path $env:TEMP ([System.Guid]::NewGuid().ToString() + ".ps1")
        Set-Content -Path $tempScriptPath -Value $scriptContent -Encoding UTF8 -ErrorAction Stop
        Write-Host "Script saved to $tempScriptPath"

        # Arguments for the elevated process
        $arguments = "-NoProfile -ExecutionPolicy Bypass -File `"$tempScriptPath`""

        # Start the elevated process
        Start-Process powershell.exe -ArgumentList $arguments -Verb RunAs -ErrorAction Stop
        Write-Host "Elevated process started. Exiting current process."

    } catch {
        Write-Error "Failed to restart script with administrator privileges: $($_.Exception.Message)"
        Write-Warning "Please download the script and run it manually as administrator."
        Read-Host "Press Enter to exit..."
    }
    # Exit the current non-admin instance immediately
    exit
} else {
    Write-Host "Script is running with administrator privileges." -ForegroundColor Green
    # Clean up temporary script file if it exists from a previous relaunch attempt
    # Note: This check is basic; a more robust cleanup might be needed in complex scenarios.
    Get-ChildItem -Path $env:TEMP -Filter "*.ps1" | Where-Object { $_.Name -match '^[0-9a-f]{8}-([0-9a-f]{4}-){3}[0-9a-f]{12}\.ps1$' -and $_.CreationTime -lt (Get-Date).AddMinutes(-5) } | Remove-Item -Force -ErrorAction SilentlyContinue
}

# --- OS Check ---
Write-Host "Checking Operating System version..."
try {
    $osInfo = Get-CimInstance -ClassName Win32_OperatingSystem -ErrorAction Stop
    $osVersion = [Version]$osInfo.Version
    $minVersion = [Version]"10.0"
    if ($osVersion -lt $minVersion) {
        Write-Error "Unsupported OS: This script requires Windows 10 or newer. Your version: $($osInfo.Caption) ($($osInfo.Version))"
        Read-Host "Press Enter to exit..."
        exit
    } else {
        Write-Host "Operating System is supported: $($osInfo.Caption) (Version $($osInfo.Version))" -ForegroundColor Green
    }
} catch {
    Write-Warning "Could not determine OS version: $($_.Exception.Message)"
}
#endregion Initial Checks

#region Shortcut Creation (Modified for irm | iex)
# --- Shortcut Creation ---
Write-Host "Checking/Creating Desktop Shortcut..."
$shortcutName = "CS_Script_Utility.lnk"
$shortcutPath = [System.IO.Path]::Combine([System.Environment]::GetFolderPath('Desktop'), $shortcutName)
$targetExecutable = "C:\Windows\System32\WindowsPowerShell\v1.0\powershell.exe"
# Arguments to run the script via irm | iex using the configured URL
# Use -WindowStyle Hidden ? Maybe not, user should see the console temporarily.
$shortcutArguments = "-NoProfile -ExecutionPolicy Bypass -Command `"irm '$($scriptUrl -replace "'", "''")' | iex`"" # Escape single quotes in URL for command string

$iconUrl = "https://catsmoker.github.io/web/assets/ico/favicon.ico" # Keep original icon URL
$localIconPath = [System.IO.Path]::Combine($env:TEMP, "CS_Script_Icon.ico")

# Download icon (same logic as before)
if (-not (Test-Path $localIconPath)) {
    Write-Host "Downloading shortcut icon..."
    try { Invoke-WebRequest -Uri $iconUrl -OutFile $localIconPath -UseBasicParsing -ErrorAction Stop; Write-Host "Icon downloaded." -ForegroundColor Green }
    catch { Write-Warning "Failed to download icon: $($_.Exception.Message)"; $localIconPath = $null }
}

$wshShell = $null
try {
    $wshShell = New-Object -ComObject WScript.Shell
    $shortcut = $wshShell.CreateShortcut($shortcutPath)
    $needsUpdate = $false
    if ($shortcut.TargetPath -ne $targetExecutable) { $shortcut.TargetPath = $targetExecutable; $needsUpdate = $true }
    # Compare arguments carefully
    if ($shortcut.Arguments -ne $shortcutArguments) { $shortcut.Arguments = $shortcutArguments; $needsUpdate = $true }
    if ($shortcut.WorkingDirectory -ne ([System.IO.Path]::GetDirectoryName($targetExecutable))) { $shortcut.WorkingDirectory = [System.IO.Path]::GetDirectoryName($targetExecutable); $needsUpdate = $true }
    if ($localIconPath -and (Test-Path $localIconPath) -and $shortcut.IconLocation -ne "$localIconPath,0") { $shortcut.IconLocation = "$localIconPath,0"; $needsUpdate = $true }
    elseif (-not $localIconPath -and -not [string]::IsNullOrEmpty($shortcut.IconLocation)) { $shortcut.IconLocation = ""; $needsUpdate = $true }

    if ($needsUpdate -or -not (Test-Path $shortcutPath)) {
        Write-Host "Creating/Updating shortcut to run from URL: $shortcutPath"
        $shortcut.Save()
        Write-Host "Shortcut processed successfully." -ForegroundColor Green
    } else {
        Write-Host "Desktop shortcut is already up to date."
    }
} catch {
    Write-Warning "Failed to create/update shortcut: $($_.Exception.Message)"
} finally {
    if ($wshShell -ne $null) { [System.Runtime.InteropServices.Marshal]::ReleaseComObject($wshShell) | Out-Null; Remove-Variable wshShell -ErrorAction SilentlyContinue }
}
