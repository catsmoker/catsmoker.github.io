Function Scan-WithMRT {
    Update-Status "Preparing Windows Malicious Software Removal Tool (MRT)..." 0
    $script:mainForm.Cursor = [System.Windows.Forms.Cursors]::WaitCursor
    Write-Host "--- Starting MRT Scan ---"

    try {
        $mrtPath = Join-Path -Path $env:SystemRoot -ChildPath "System32\MRT.exe"

        if (-not (Test-Path $mrtPath)) {
            throw "MRT.exe not found at expected location: $mrtPath"
        }

        Update-Status "Launching MRT Scan (Full Scan)..." 50
        Write-Host "Launching MRT.exe with /F (Full Scan) argument. Please follow the prompts in the MRT window."

        # Run MRT interactively with Full Scan argument (/F)
        # /Q = Quiet (no UI), /Q /N = Quiet Detect Only, /F = Full Scan (interactive), /F:Y = Full Scan + Auto Clean
        Start-Process -FilePath $mrtPath -ArgumentList "/F" -Wait -ErrorAction Stop
        # -Wait ensures this script pauses until MRT is closed.

        Update-Status "MRT Scan window closed." 100
        Write-Host "--- MRT Scan process finished ---"
        [System.Windows.Forms.MessageBox]::Show("The Windows Malicious Software Removal Tool has finished or was closed.", "MRT Scan Finished", [System.Windows.Forms.MessageBoxButtons]::OK, [System.Windows.Forms.MessageBoxIcon]::Information)

    } catch {
        Update-Status "Error running MRT Scan: $($_.Exception.Message)" 100
        Write-Error "Error running MRT Scan: $($_.Exception.Message)"
        [System.Windows.Forms.MessageBox]::Show("An error occurred while trying to run the MRT Scan: $($_.Exception.Message)", "MRT Error", [System.Windows.Forms.MessageBoxButtons]::OK, [System.Windows.Forms.MessageBoxIcon]::Error)
    } finally {
        $script:mainForm.Cursor = [System.Windows.Forms.Cursors]::Default
    }
}

