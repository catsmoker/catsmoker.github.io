# Helper function to update status and progress
Function Update-Status {
    param(
        [string]$Message,
        [int]$Progress = -1 # -1 means don't change progress
    )
    if ($script:mainForm.InvokeRequired) {
        $script:mainForm.Invoke([Action[string,int]]$UpdateStatus, $Message, $Progress)
    } else {
        $script:statusLabel.Text = $Message
        if ($Progress -ge 0 -and $Progress -le 100) {
            $script:progressBar.Value = $Progress
        }
        $script:statusLabel.Refresh() # Force update
        $script:progressBar.Refresh() # Force update
    }
}

