#Requires -RunAsAdministrator

#region Admin Check
# Although #Requires handles the check, this provides a friendlier relaunch mechanism.
Write-Host "Checking if running as administrator..."
$currentUser = [System.Security.Principal.WindowsIdentity]::GetCurrent()
$windowsPrincipal = New-Object System.Security.Principal.WindowsPrincipal($currentUser)
$adminRole = [System.Security.Principal.WindowsBuiltInRole]::Administrator

if (-not $windowsPrincipal.IsInRole($adminRole)) {
    $separator = "=" * 60
    $adminMessage = "Administrator Privileges Required!"
    Write-Host $separator -ForegroundColor Yellow
    Write-Host ""
    Write-Host $adminMessage -ForegroundColor Red -BackgroundColor Black -NoNewline; Write-Host " (Detected)" -ForegroundColor Yellow
    Write-Host ""
    Write-Host "This script needs administrator privileges to perform its tasks effectively." -ForegroundColor Magenta
    Write-Host "Attempting to restart with elevated rights..." -ForegroundColor Green
    Write-Host ""
    Write-Host $separator -ForegroundColor Yellow

    # Restart the script with administrative privileges
    try {
        $scriptPath = $PSCommandPath
        if ([string]::IsNullOrWhiteSpace($scriptPath)) {
             # Fallback if $PSCommandPath is empty (e.g., running selection in ISE)
             $scriptPath = $MyInvocation.MyCommand.Path
        }
        if ([string]::IsNullOrWhiteSpace($scriptPath)) {
            throw "Could not determine the script path to restart."
        }
        Start-Process powershell.exe -ArgumentList "-NoProfile -ExecutionPolicy Bypass -File `"$scriptPath`"" -Verb RunAs -ErrorAction Stop
    } catch {
        Write-Warning "Failed to restart script with administrator privileges: $($_.Exception.Message)"
        Write-Host "Please right-click the script file and select 'Run as administrator'." -ForegroundColor Yellow
        Read-Host "Press Enter to exit..."
    }
    exit # Exit the current non-admin instance
} else {
    Write-Host "Script is running with administrator privileges." -ForegroundColor Green
}
#endregion Admin Check

#region OS Check
Write-Host "Checking Operating System version..."
try {
    $osInfo = Get-CimInstance -ClassName Win32_OperatingSystem -ErrorAction Stop
    $osVersion = [Version]$osInfo.Version
    $minVersion = [Version]"10.0"

    if ($osVersion -lt $minVersion) {
        Write-Host "------------------------------------------------------------" -ForegroundColor Red
        Write-Host "Unsupported OS: This script requires Windows 10 or newer." -ForegroundColor Red
        Write-Host "Your current OS: $($osInfo.Caption) (Version $($osInfo.Version))" -ForegroundColor Red
        Write-Host "------------------------------------------------------------" -ForegroundColor Red
        Read-Host "Press Enter to exit..."
        exit
    } else {
        Write-Host "Operating System is supported: $($osInfo.Caption) (Version $($osInfo.Version))" -ForegroundColor Green
    }
} catch {
    Write-Warning "Could not determine OS version: $($_.Exception.Message)"
    # Optionally proceed with caution or exit
    # Read-Host "Could not verify OS version. Press Enter to attempt to continue anyway, or Ctrl+C to exit..."
}
#endregion OS Check

#region Shortcut Creation
Write-Host "Checking/Creating Desktop Shortcut..."
$shortcutName = "CS_Script_Utility.lnk" # Changed name slightly
$shortcutPath = [System.IO.Path]::Combine([System.Environment]::GetFolderPath('Desktop'), $shortcutName)
$targetScriptPath = $PSCommandPath # Shortcut will run this script
$targetExecutable = "C:\Windows\System32\WindowsPowerShell\v1.0\powershell.exe"
# Arguments to run the current script elevated via the shortcut
$arguments = "-NoProfile -ExecutionPolicy Bypass -Command `"Start-Process powershell.exe -ArgumentList '-NoProfile -ExecutionPolicy Bypass -File `\`"$($targetScriptPath.Replace("'", "''"))`\`"' -Verb RunAs`""

# Define the URL for the icon and the path to save it locally in TEMP
$iconUrl = "https://catsmoker.github.io/web/assets/ico/favicon.ico"
$localIconPath = [System.IO.Path]::Combine($env:TEMP, "CS_Script_Icon.ico")

# Download the icon (only if it doesn't exist or is outdated - simple check here)
if (-not (Test-Path $localIconPath)) {
    Write-Host "Downloading shortcut icon..."
    try {
        Invoke-WebRequest -Uri $iconUrl -OutFile $localIconPath -UseBasicParsing -ErrorAction Stop
        Write-Host "Icon downloaded to $localIconPath" -ForegroundColor Green
    } catch {
        Write-Warning "Failed to download icon: $($_.Exception.Message). Shortcut will use default icon."
        $localIconPath = $null # Ensure we don't try to use a non-existent path
    }
}

# Create or update the shortcut
$wshShell = $null
try {
    $wshShell = New-Object -ComObject WScript.Shell
    $shortcut = $wshShell.CreateShortcut($shortcutPath)

    # Check if properties need updating
    $needsUpdate = $false
    if ($shortcut.TargetPath -ne $targetExecutable) { $shortcut.TargetPath = $targetExecutable; $needsUpdate = $true }
    if ($shortcut.Arguments -ne $arguments) { $shortcut.Arguments = $arguments; $needsUpdate = $true }
    if ($shortcut.WorkingDirectory -ne ([System.IO.Path]::GetDirectoryName($targetExecutable))) { $shortcut.WorkingDirectory = [System.IO.Path]::GetDirectoryName($targetExecutable); $needsUpdate = $true }
    if ($localIconPath -and (Test-Path $localIconPath) -and $shortcut.IconLocation -ne "$localIconPath,0") {
        $shortcut.IconLocation = "$localIconPath,0" # Add ,0 for index if needed
        $needsUpdate = $true
    } elseif (-not $localIconPath -and -not [string]::IsNullOrEmpty($shortcut.IconLocation)) {
         # If icon download failed, remove any old icon setting
         $shortcut.IconLocation = ""
         $needsUpdate = $true
    }

    if ($needsUpdate -or -not (Test-Path $shortcutPath)) {
        Write-Host "Creating/Updating shortcut: $shortcutPath"
        $shortcut.Save()
        Write-Host "Shortcut processed successfully." -ForegroundColor Green
    } else {
        Write-Host "Desktop shortcut is already up to date."
    }
} catch {
    Write-Warning "Failed to create/update shortcut: $($_.Exception.Message)"
} finally {
    # Release COM object
    if ($wshShell -ne $null) {
        [System.Runtime.InteropServices.Marshal]::ReleaseComObject($wshShell) | Out-Null
        Remove-Variable wshShell # Clean up variable
    }
}
