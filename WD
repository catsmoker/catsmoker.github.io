                    $packageId = $packageInfo.ID
                    $progress = 20 + (($completedPackages / $totalPackages) * 80) # Scale progress from 20% to 100%
                    Update-Status "Installing $($packageName) ($($completedPackages + 1)/$totalPackages)..." $progress
                    Write-Host "Installing '$packageName' (ID: $packageId)..."
                    try {
                        # Using --force allows reinstall/upgrade over existing versions if needed
                        Start-Process "winget" -ArgumentList "install -e --id `"$packageId`" --silent --accept-package-agreements --accept-source-agreements --disable-interactivity --force" -Wait -NoNewWindow -ErrorAction Stop
                        Write-Host "'$packageName' installation command completed." -ForegroundColor Green
                    } catch {
                         Write-Warning "Failed to install '$packageName': $($_.Exception.Message)"
                         # Optionally show a message box per failure or collect errors
                    }
                    $completedPackages++
                }

                Update-Status "Selected software installation process finished." 100
                Write-Host "--- Installation process finished ---"
                [System.Windows.Forms.MessageBox]::Show("Installation process for selected packages has finished. Check the console output for details on individual successes or failures.", "Installation Finished", [System.Windows.Forms.MessageBoxButtons]::OK, [System.Windows.Forms.MessageBoxIcon]::Information)
            }
        } else {
             Update-Status "App selection cancelled." 0
        }

    } catch {
        Update-Status "Error in Apps/Upgrades: $($_.Exception.Message)" 0
        Write-Error "Error in Apps/Upgrades function: $($_.Exception.Message)"
        [System.Windows.Forms.MessageBox]::Show("An unexpected error occurred: $($_.Exception.Message)", "Error", [System.Windows.Forms.MessageBoxButtons]::OK, [System.Windows.Forms.MessageBoxIcon]::Error)
    } finally {
        $script:mainForm.Cursor = [System.Windows.Forms.Cursors]::Default
        # Dispose the app selection form if it was created
        if ($Form -ne $null) { $Form.Dispose() }
    }
}

# Renamed from windows-ps
Function Run-WindowsUpdate {
    Update-Status "Checking for Windows Updates..." 0
    $script:mainForm.Cursor = [System.Windows.Forms.Cursors]::WaitCursor
    Write-Host "--- Starting Windows Update process ---"

    try {
        # Check if PSWindowsUpdate module is installed
        $moduleName = "PSWindowsUpdate"
        $logFileName = "$($env:computername)-$(Get-Date -f yyyy-MM-dd)-MSUpdates.log"
        $logFilePath = Join-Path $env:TEMP $logFileName

        if (-not (Get-Module -ListAvailable -Name $moduleName)) {
            Update-Status "PSWindowsUpdate module not found. Installing..." 10
            Write-Host "Installing PSWindowsUpdate module..."
            # Ensure NuGet provider is available
            if (-not (Get-PackageProvider -Name NuGet -ErrorAction SilentlyContinue)) {
                Write-Host "Installing NuGet package provider..."
                Install-PackageProvider -Name NuGet -MinimumVersion 2.8.5.201 -Force -ErrorAction Stop
            }
            Install-Module $moduleName -Force -AcceptLicense -Scope CurrentUser -ErrorAction Stop # Install for current user (admin)
            Update-Status "PSWindowsUpdate module installed." 20
        } else {
             Write-Host "PSWindowsUpdate module already installed."
             Update-Status "PSWindowsUpdate module found." 20
        }

        # Import the module if not already imported
        Import-Module $moduleName -ErrorAction Stop

        # Add Microsoft Update service if not already registered
        Update-Status "Registering Microsoft Update service (if needed)..." 30
        Write-Host "Registering Microsoft Update service..."
        Add-WUServiceManager -ServiceID "7971f918-a847-4430-9279-4a52d1efe18d" -Confirm:$false -ErrorAction SilentlyContinue # Service ID for Microsoft Update

        # Check for, download, and install updates
        Update-Status "Checking for updates..." 40
        Write-Host "Checking for updates (logging to $logFilePath)..."
        # Get-WindowsUpdate will list available updates
        # Install-WindowsUpdate will download and install them
        # Using -MicrosoftUpdate ensures updates for other MS products are included
        # -AcceptAll accepts all updates
        # -AutoReboot allows automatic reboot if necessary (Use with caution!) Consider removing or adding confirmation.
        # For safer execution, remove -AutoReboot and inform the user.
        Install-WindowsUpdate -MicrosoftUpdate -AcceptAll -Verbose | Out-File $logFilePath -Append
        # Consider adding: -IgnoreReboot (to prevent auto-reboot but flag that one is needed)

        Update-Status "Windows Update check and installation process completed." 100
        Write-Host "--- Windows Update process finished ---"
        [System.Windows.Forms.MessageBox]::Show("Windows Update process finished. A reboot may be required. Check the log file for details:`n$logFilePath", "Updates Complete", [System.Windows.Forms.MessageBoxButtons]::OK, [System.Windows.Forms.MessageBoxIcon]::Information)

    } catch {
        Update-Status "Error during Windows Update: $($_.Exception.Message)" 100
        Write-Error "Error during Windows Update: $($_.Exception.Message)"
        [System.Windows.Forms.MessageBox]::Show("An error occurred during the Windows Update process. Check console output for details.", "Update Error", [System.Windows.Forms.MessageBoxButtons]::OK, [System.Windows.Forms.MessageBoxIcon]::Error)
    } finally {
        $script:mainForm.Cursor = [System.Windows.Forms.Cursors]::Default
    }
}

