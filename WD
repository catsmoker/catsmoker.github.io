Function Clean-Windows {
    Update-Status "Cleaning Windows..." 0
    $script:mainForm.Cursor = [System.Windows.Forms.Cursors]::WaitCursor

    try {
        # Clean User Temp Folder
        $userTempPath = $env:TEMP
        Update-Status "Clearing user temp folder: $userTempPath" 10
        Write-Host "Clearing user temp folder: $userTempPath"
        Get-ChildItem -Path $userTempPath -Recurse -Force -ErrorAction SilentlyContinue | ForEach-Object {
            try {
                Remove-Item -Path $_.FullName -Recurse -Force -ErrorAction Stop
            } catch {
                Write-Warning "Could not remove '$($_.FullName)': $($_.Exception.Message)"
            }
        }
        Update-Status "User temp folder cleared." 30

        # Clean Windows Temp Folder
        $windowsTempPath = Join-Path -Path $env:windir -ChildPath "Temp"
        Update-Status "Clearing Windows temp folder: $windowsTempPath" 40
        Write-Host "Clearing Windows temp folder: $windowsTempPath"
        Get-ChildItem -Path $windowsTempPath -Recurse -Force -ErrorAction SilentlyContinue | ForEach-Object {
            try {
                Remove-Item -Path $_.FullName -Recurse -Force -ErrorAction Stop
            } catch {
                Write-Warning "Could not remove '$($_.FullName)': $($_.Exception.Message)"
            }
        }
        Update-Status "Windows temp folder cleared." 60

        # Clean Recycle Bin with Confirmation
        Update-Status "Checking Recycle Bin..." 70
        $RecycleBin = (New-Object -ComObject Shell.Application).NameSpace(0xA)
        if ($RecycleBin.Items().Count -gt 0) {
            $confirm = [System.Windows.Forms.MessageBox]::Show("Do you want to permanently empty the Recycle Bin?", "Confirm Delete", [System.Windows.Forms.MessageBoxButtons]::YesNo, [System.Windows.Forms.MessageBoxIcon]::Warning)
            if ($confirm -eq [System.Windows.Forms.DialogResult]::Yes) {
                Update-Status "Emptying Recycle Bin..." 80
                Write-Host "Emptying Recycle Bin..."
                try {
                    $RecycleBin.Items() | ForEach-Object { $_.InvokeVerb("delete") } # Needs testing if silent delete works directly
                    # Fallback / alternative: Clear-RecycleBin cmdlet (requires PowerShell 5+)
                    # Clear-RecycleBin -Force -ErrorAction SilentlyContinue
                    Update-Status "Recycle Bin emptied." 90
                } catch {
                     Write-Warning "Failed to empty Recycle Bin: $($_.Exception.Message)"
                     Update-Status "Failed to empty Recycle Bin." 90
                }
            } else {
                Update-Status "Recycle Bin unchanged." 90
            }
        } else {
             Update-Status "Recycle Bin is already empty." 90
        }


        # Flush DNS Cache
        Update-Status "Flushing DNS Cache..." 95
        Write-Host "Flushing DNS Cache..."
        try {
            Start-Process -FilePath "ipconfig.exe" -ArgumentList "/flushdns" -NoNewWindow -Wait -ErrorAction Stop
        } catch {
            Write-Warning "Failed to flush DNS cache: $($_.Exception.Message)"
        }

        Update-Status "Cleanup completed!" 100
    } catch {
        Update-Status "Error during cleanup: $($_.Exception.Message)" 100
        Write-Error "Error during cleanup: $($_.Exception.Message)"
    } finally {
        $script:mainForm.Cursor = [System.Windows.Forms.Cursors]::Default
    }
}

Function Fix-Windows {
    Update-Status "Scanning and fixing Windows..." 0
    $script:mainForm.Cursor = [System.Windows.Forms.Cursors]::WaitCursor
    Write-Host "--- Starting Windows Fix sequence ---"

    try {
        # Run chkdsk (Scan only, needs reboot for fixes)
        Update-Status "Running Check Disk (Scan)..." 10
        Write-Host "Running chkdsk /scan..."
        # Note: chkdsk /f requires a reboot and cannot be easily waited on here. /scan is safer.
        Start-Process -FilePath "chkdsk.exe" -ArgumentList "/scan /perf" -NoNewWindow -Wait -ErrorAction Stop
        Update-Status "Check Disk (Scan) completed." 30

        # Run sfc /scannow
        Update-Status "Running System File Checker (SFC)..." 40
        Write-Host "Running sfc /scannow..."
        Start-Process -FilePath "sfc.exe" -ArgumentList "/scannow" -NoNewWindow -Wait -ErrorAction Stop
        Update-Status "System File Checker completed." 60

        # Run DISM
        Update-Status "Running Deployment Imaging Service and Management Tool (DISM)..." 70
        Write-Host "Running DISM /Online /Cleanup-Image /RestoreHealth..."
        Start-Process -FilePath "DISM.exe" -ArgumentList "/Online /Cleanup-Image /RestoreHealth" -NoNewWindow -Wait -ErrorAction Stop
        Update-Status "DISM completed." 90

        Update-Status "Windows Fix sequence completed!" 100
        Write-Host "--- Windows Fix sequence finished ---"
        [System.Windows.Forms.MessageBox]::Show("Windows Fix sequence completed. Check the console output for details. A restart may be required for some fixes.", "Fix Complete", [System.Windows.Forms.MessageBoxButtons]::OK, [System.Windows.Forms.MessageBoxIcon]::Information)

    } catch {
        Update-Status "Error during Fix sequence: $($_.Exception.Message)" 100
        Write-Error "Error during Fix sequence: $($_.Exception.Message)"
        [System.Windows.Forms.MessageBox]::Show("An error occurred during the Fix sequence. Check console output for details.", "Error", [System.Windows.Forms.MessageBoxButtons]::OK, [System.Windows.Forms.MessageBoxIcon]::Error)
    } finally {
        $script:mainForm.Cursor = [System.Windows.Forms.Cursors]::Default
    }
}

